{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST https://mt-push.jaga-farm.com/v1/notify -H 'Content-Type: application/json' -d '{\"token\":\"YOUR-DEVICE-SECRET\",\"event\":\"agent-done\",\"message\":\"Task complete\"}' > /dev/null 2>&1 &"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST https://mt-push.jaga-farm.com/v1/notify -H 'Content-Type: application/json' -d '{\"token\":\"YOUR-DEVICE-SECRET\",\"event\":\"agent-input\",\"message\":\"Permission needed\"}' > /dev/null 2>&1 &"
          }
        ]
      }
    ]
  }
}
